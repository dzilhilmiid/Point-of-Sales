<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-rc4/dist/css/adminlte.min.css"/>
    
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
    <div class="logo">POS APP</div>
    <a href="/dashboard" class="active">Dashboard</a>
    <a href="/members">Members</a>
    <a href="#">Transactions</a>
    <a href="/users">Users</a>
</div>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
        <div></div>
        <div class="profile">
            <span>Admin Pos</span>
            <div class="dropdown">
                <a href="/profile">Profile</a>
                <a href="/settings">Settings</a>
                <a href="/activity">Activity</a>
                <a href="/logout" onclick="return confirm('Logout sekarang?')">Logout</a>
            </div>
        </div>
    </div>

    <div class="content">
        <h2>Edit Member</h2>
        <form method="POST">
        <input name="name" value="<%= member.name %>" required><br>
        <input name="phone" value="<%= member.phone %>"><br>
        <textarea name="address"><%= member.address %></textarea><br>
        <button type="submit">Update</button>
        </form>
    </div>