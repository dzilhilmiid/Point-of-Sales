<h2 class="page-title">Executive Dashboard</h2>

<!-- ================= KPI SECTION ================= -->
<div class="metrics-grid">

  <div class="metric-card">
    <div class="metric-title">Total Revenue</div>
    <div class="metric-value">
      Rp <%= Number(totalSales || 0).toLocaleString("id-ID") %>
    </div>
  </div>

  <div class="metric-card">
    <div class="metric-title">Orders</div>
    <div class="metric-value">
      <%= Number(totalOrders || 0).toLocaleString("id-ID") %>
    </div>
  </div>

  <div class="metric-card">
    <div class="metric-title">Customers</div>
    <div class="metric-value">
      <%= Number(totalCustomers || 0).toLocaleString("id-ID") %>
    </div>
  </div>

  <div class="metric-card highlight">
    <div class="metric-title">Today</div>
    <div class="metric-value">
      Rp <%= Number(today || 0).toLocaleString("id-ID") %>
    </div>
  </div>

</div>


<!-- ================= MAIN GRID ================= -->
<div class="dashboard-main">

  <!-- ===== LINE CHART ===== -->
  <div class="dashboard-card large compact">

    <div class="card-header">
      <h3>Revenue Trend</h3>

      <div style="display:flex; gap:10px; align-items:center;">
        <span style="opacity:.6; font-size:13px;">
          Last <%= chartLabels.length %> Days
        </span>

        <a href="/dashboard/export" class="btn-export">
          Export CSV
        </a>
      </div>

    </div>

    <div class="chart-container">
      <canvas id="lineChart"></canvas>
    </div>

  </div>


  <!-- ===== PIE CHART ===== -->
  <div class="dashboard-card compact">

    <div class="card-header">
      <h3>Revenue Sources</h3>
    </div>

    <div class="chart-container">
      <canvas id="pieChart"></canvas>
    </div>

  </div>

</div>



<!-- ================= SYSTEM SNAPSHOT ================= -->
<div class="dashboard-card compact">

  <div class="card-header">
    <h3>System Snapshot</h3>
  </div>

  <div class="summary-item">
    <span>Members</span>
    <strong><%= totalMembers %></strong>
  </div>

  <div class="summary-item">
    <span>Goods</span>
    <strong><%= totalGoods %></strong>
  </div>

  <div class="summary-item">
    <span>Suppliers</span>
    <strong><%= totalSuppliers %></strong>
  </div>

  <div class="summary-item">
    <span>Purchases</span>
    <strong><%= totalPurchases %></strong>
  </div>

  <hr style="opacity:.1; margin:15px 0;">

  <div class="summary-item">
    <span>Avg Revenue / Order</span>
    <strong>
      Rp <%= totalOrders > 0
            ? Math.round(totalSales / totalOrders).toLocaleString("id-ID")
            : 0 %>
    </strong>
  </div>

</div>



<!-- ================= DATE FILTER ================= -->

<div class="dashboard-card compact">

  <div class="card-header">
    <h3>Date Settings</h3>
  </div>

  <form method="GET" action="/dashboard">

    <div class="filter-grid">

      <div>
        <label>Start Date</label>
        <input type="date" name="start">
      </div>

      <div>
        <label>End Date</label>
        <input type="date" name="end">
      </div>

      <div style="display:flex;align-items:end;">
        <button type="submit" class="btn-filter">
          Apply
        </button>
      </div>

    </div>

  </form>

</div>



<!-- ================= RECENT TRANSACTIONS ================= -->

<div class="dashboard-card compact">

  <div class="card-header">
    <h3>Recent Transactions</h3>
  </div>

  <table class="table-dashboard">

    <thead>
      <tr>
        <th>Date</th>
        <th>Invoice</th>
        <th>Total</th>
      </tr>
    </thead>

    <tbody>

      <% if(recentSales.length === 0){ %>

        <tr>
          <td colspan="3" style="text-align:center; opacity:.6;">
            No transactions
          </td>
        </tr>

      <% } %>

      <% recentSales.forEach(row => { %>

      <tr>

        <td>
          <%= new Date(row.created_at).toLocaleDateString("id-ID") %>
        </td>

        <td>
          <%= row.invoice_number %>
        </td>

        <td>
          Rp <%= Number(row.total).toLocaleString("id-ID") %>
        </td>

      </tr>

      <% }) %>

    </tbody>

  </table>

</div>



<!-- ================= CHART ================= -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const labels = <%- JSON.stringify(chartLabels || []) %>;
const totals = <%- JSON.stringify(chartTotals || []) %>;


// ===== LINE CHART =====

new Chart(document.getElementById('lineChart'), {

  type: 'line',

  data: {
    labels: labels,
    datasets: [{
      label: 'Revenue',
      data: totals,
      borderColor: '#2563eb',
      backgroundColor: 'rgba(37,99,235,0.08)',
      borderWidth: 2,
      tension: 0.35,
      fill: true,
      pointRadius: 3
    }]
  },

  options: {
    responsive: true,
    maintainAspectRatio: false,

    plugins: {
      legend: { display: false },

      tooltip: {
        callbacks: {
          label: function(context) {
            return 'Rp ' + context.raw.toLocaleString('id-ID');
          }
        }
      }
    },

    scales: {
      y: {
        beginAtZero: true,
        ticks: {
          callback: function(value) {
            return 'Rp ' + value.toLocaleString('id-ID');
          }
        }
      }
    }
  }

});


// ===== PIE CHART =====

const pieData = <%- JSON.stringify([
  Math.round(totalSales * 0.7),
  Math.round(totalSales * 0.3)
]) %>;

new Chart(document.getElementById('pieChart'), {

  type: 'doughnut',

  data: {
    labels: ['Direct', 'Customer'],
    datasets: [{
      data: pieData,
      backgroundColor: [
        '#2563eb',
        '#22c55e'
      ]
    }]
  },

  options:{
    responsive:true,
    plugins:{
      legend:{
        position:'bottom'
      }
    }
  }

});
</script>