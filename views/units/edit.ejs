<!DOCTYPE html>
<html>
<head>
    <title>Units</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-rc4/dist/css/adminlte.min.css"/>
    
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
    <div class="logo">POS APP</div>
    <a href="/dashboard" class="active">Dashboard</a>
    <a href="/members">Members</a>
    <a href="/units">Units</a>
    <a href="/users">Users</a>
</div>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <div class="topbar">
        <div></div>
        <div class="profile">
            <span>Admin Pos</span>
            <div class="dropdown">
                <a href="/profile">Profile</a>
                <a href="/settings">Settings</a>
                <a href="/activity">Activity</a>
                <a href="/logout" onclick="return confirm('Logout sekarang?')">Logout</a>
            </div>
        </div>
    </div>
<h2>Edit Unit</h2>

<form method="POST">
    <input type="text" name="unit" value="<%= unit.unit %>">
    <textarea name="note"><%= unit.note %></textarea>
    <button type="submit">Update</button>
</form>

</body>
</html>